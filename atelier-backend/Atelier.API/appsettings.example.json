{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=AtelierDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TimeZone": {
    "Id": "SE Asia Standard Time"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_HERE_MINIMUM_32_CHARS",
    "Issuer": "AtelierAPI",
    "Audience": "AtelierClient",
    "ExpirationMinutes": 1440
  },
  "UploadSettings": {
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp"]
  },
  "VnPay": {
    "BaseUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html",
    "TmnCode": "YOUR_VNPAY_TMN_CODE",
    "HashSecret": "YOUR_VNPAY_HASH_SECRET",
    "ReturnUrl": "http://localhost:5097/api/Payments/vnpay-return",
    "IpnUrl": "https://your-ngrok-url.ngrok-free.dev/api/Payments/vnpay-ipn"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3001"
  },
  "GHN": {
    "BaseUrl": "https://dev-online-gateway.ghn.vn/shiip/public-api/v2",
    "Token": "YOUR_GHN_TOKEN",
    "MasterDataToken": "YOUR_GHN_MASTER_DATA_TOKEN",
    "ShopId": 0,
    "FromPhone": "YOUR_PHONE",
    "FromAddress": "YOUR_ADDRESS",
    "FromWardCode": "YOUR_WARD_CODE",
    "FromDistrictId": 0
  },
  "ShipmentPolling": {
    "IntervalSeconds": 60
  },
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "Model": "gemini-3.1-flash-lite",
    "ApiUrl": "https://generativelanguage.googleapis.com/v1beta/models/"
  },
  "Lalamove": {
    "PublicKey": "YOUR_LALAMOVE_PUBLIC_KEY",
    "SecretKey": "YOUR_LALAMOVE_SECRET_KEY",
    "BaseUrl": "https://rest.sandbox.lalamove.com",
    "Market": "VN",
    "StoreLat": 0,
    "StoreLng": 0,
    "StoreAddress": "YOUR_STORE_ADDRESS",
    "StorePhone": "YOUR_PHONE",
    "StoreName": "Atelier Shop"
  }
}
